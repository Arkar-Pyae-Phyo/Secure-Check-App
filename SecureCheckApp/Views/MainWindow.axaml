<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:SecureCheckApp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="700"
        x:Class="SecureCheckApp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Secure Check App"
        Icon="/ico/favicon.ico"
        Width="600" Height="700"
        CanResize="False"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">

    <Window.Background>
        <SolidColorBrush Color="#F4F5F7"/>
    </Window.Background>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <!-- Button Styles with Animations -->
        <Style Selector="Button.primary">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="35,16"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#991B1B" Offset="0"/>
                    <GradientStop Color="#7F1D1D" Offset="1"/>
                </LinearGradientBrush>
            </Setter>
        </Style>

        <Style Selector="Button.primary:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.05)"/>
        </Style>

        <Style Selector="Button.primary:pointerover TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="Button.primary TextBlock">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Foreground" Duration="0:0:0.3"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.primary:pressed">
            <Setter Property="RenderTransform" Value="scale(0.98)"/>
            <Setter Property="Opacity" Value="0.9"/>
        </Style>

        <Style Selector="Button.primary /template/ ContentPresenter">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.3"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#B91C1C" Offset="0"/>
                    <GradientStop Color="#991B1B" Offset="1"/>
                </LinearGradientBrush>
            </Setter>
        </Style>

        <Style Selector="Button.primary:pressed /template/ ContentPresenter">
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#7F1D1D" Offset="0"/>
                    <GradientStop Color="#450A0A" Offset="1"/>
                </LinearGradientBrush>
            </Setter>
        </Style>

        <Style Selector="Button.primary:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#CBD5E1"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
        </Style>

        <Style Selector="Button.refresh">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="40,12"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                    <GradientStop Color="#475569" Offset="0"/>
                    <GradientStop Color="#334155" Offset="1"/>
                </LinearGradientBrush>
            </Setter>
        </Style>

        <Style Selector="Button.refresh:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.05)"/>
        </Style>

        <Style Selector="Button.refresh:pointerover TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="Button.refresh TextBlock">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Foreground" Duration="0:0:0.3"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.refresh:pressed">
            <Setter Property="RenderTransform" Value="scale(0.98)"/>
            <Setter Property="Opacity" Value="0.9"/>
        </Style>

        <Style Selector="Button.refresh /template/ ContentPresenter">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.3"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.refresh:pointerover /template/ ContentPresenter">
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                    <GradientStop Color="#64748B" Offset="0"/>
                    <GradientStop Color="#475569" Offset="1"/>
                </LinearGradientBrush>
            </Setter>
        </Style>

        <Style Selector="Button.refresh:pressed /template/ ContentPresenter">
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                    <GradientStop Color="#334155" Offset="0"/>
                    <GradientStop Color="#1E293B" Offset="1"/>
                </LinearGradientBrush>
            </Setter>
        </Style>

        <Style Selector="Button.refresh:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#CBD5E1"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
        </Style>

    </Window.Styles>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Border Grid.Row="0" 
                Padding="30,20,30,10">
            <StackPanel HorizontalAlignment="Center" Spacing="10">
                <!-- Logo -->
                <Image Source="avares://SecureCheckApp/img/dce.png"
                       Width="180"
                       Height="180"
                       HorizontalAlignment="Center"
                       Stretch="Uniform">
                        <Image.Transitions>
                            <Transitions>
                                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.4" Easing="CubicEaseOut"/>
                            </Transitions>
                        </Image.Transitions>
                    </Image>

                    <!-- Title Section -->
                    <StackPanel HorizontalAlignment="Center"
                                Spacing="8">
                        <TextBlock Text="Secured Assessment System"
                                   FontSize="38"
                                   HorizontalAlignment="Center"
                                   FontWeight="Bold"
                                   LetterSpacing="-0.5">
                            <TextBlock.Foreground>
                                <SolidColorBrush Color="#8C1D1D"/>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <TextBlock Text="Online Proctored Assessment Security Module"
                                   FontSize="16"
                                   HorizontalAlignment="Center"
                                   Foreground="#6B7280"
                                   FontWeight="Medium"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Main Content Section -->
            <Grid Grid.Row="1"
                  MaxWidth="1200"
                  Margin="30,0,30,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Action Card -->
                <Border Grid.Row="0"
                        CornerRadius="20"
                        Padding="25"
                        Margin="0,0,0,20"
                        BoxShadow="0 8 32 0 #18000000">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                            <GradientStop Color="#FFFFFF" Offset="0"/>
                            <GradientStop Color="#F8FAFC" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Transitions>
                        <Transitions>
                            <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.3"/>
                            <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.3"/>
                        </Transitions>
                    </Border.Transitions>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Action Buttons Row -->
                        <StackPanel Grid.Row="0" 
                                    Orientation="Horizontal" 
                                    HorizontalAlignment="Center"
                                    Spacing="20">
                            <Button Classes="primary"
                                    Command="{Binding RunSecurityCheckCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="🔒" FontSize="22" VerticalAlignment="Center"/>
                                    <TextBlock Text="Run Security Check" 
                                               FontSize="16"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Classes="refresh"
                                    Command="{Binding RefreshCommand}">
                                <TextBlock Text="Refresh" 
                                           FontSize="15"
                                           VerticalAlignment="Center"/>
                            </Button>

                            <!-- Continue to Exam Button (only visible when clean) -->
                            <Button Classes="primary"
                                    Command="{Binding ContinueToExamCommand}"
                                    IsVisible="{Binding ShowContinueButton}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="✅" FontSize="22" VerticalAlignment="Center"/>
                                    <TextBlock Text="Continue to Exam" 
                                               FontSize="16"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Status Information -->
                        <StackPanel Grid.Row="1" 
                                    Margin="0,25,0,0"
                                    HorizontalAlignment="Center"
                                    Spacing="12">
                            <TextBlock Text="{Binding StatusText}"
                                       FontSize="18"
                                       HorizontalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="#374151">
                                <TextBlock.Transitions>
                                    <Transitions>
                                        <BrushTransition Property="Foreground" Duration="0:0:0.3"/>
                                    </Transitions>
                                </TextBlock.Transitions>
                            </TextBlock>

                            <TextBlock Text="{Binding IPv4Address}"
                                       FontSize="16"
                                       HorizontalAlignment="Center"
                                       FontWeight="Medium"
                                       Foreground="#6B7280">
                                <TextBlock.Transitions>
                                    <Transitions>
                                        <BrushTransition Property="Foreground" Duration="0:0:0.3"/>
                                    </Transitions>
                                </TextBlock.Transitions>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Results Card -->
                <Border Grid.Row="1"
                        Background="{Binding ResultPanelBackground}"
                        BorderBrush="{Binding ResultPanelBorderBrush}"
                        BorderThickness="2"
                        CornerRadius="20"
                        Padding="25"
                        MinHeight="150"
                        BoxShadow="0 8 32 0 #18000000">
                    <Border.Transitions>
                        <Transitions>
                            <BrushTransition Property="Background" Duration="0:0:0.4"/>
                            <BrushTransition Property="BorderBrush" Duration="0:0:0.4"/>
                        </Transitions>
                    </Border.Transitions>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock Text="{Binding DetectionResults}"
                                   FontFamily="avares://SecureCheckApp/Assets/fonts#Garet"
                                   FontSize="14"
                                   Foreground="{Binding DetectionResultsForeground}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   LineHeight="26">
                            <TextBlock.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Opacity" Duration="0:0:0.3"/>
                                </Transitions>
                            </TextBlock.Transitions>
                        </TextBlock>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
</Window>
